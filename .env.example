# ─── Ollama (local LLM — free, no API key needed) ────────────────────────────
# Ollama must be running: it starts automatically on Windows after install
# Check what models you have: ollama list
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=dsa_coach
POSTGRES_PASSWORD=changeme
POSTGRES_DB=dsa_coach
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://dsa_coach:changeme@localhost:5432/dsa_coach
DATABASE_URL_SYNC=postgresql://dsa_coach:changeme@localhost:5432/dsa_coach

# ─── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=dsa_pattern_notes

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
# Comma-separated Telegram chat IDs to notify (one per user for now)
# In production this comes from the DB; here it's a fallback
TELEGRAM_DEFAULT_CHAT_ID=123456789

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development               # development | production
APP_SECRET_KEY=supersecretkey32chars
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
LOG_LEVEL=INFO

# ─── Celery Beat Schedule ─────────────────────────────────────────────────────
DAILY_NUDGE_HOUR=18               # 6 PM
DAILY_NUDGE_MINUTE=0
DAILY_NUDGE_TIMEZONE=Asia/Kolkata
